{
  "nva_version": "0.2",
  "meta": {
    "name": "데모 박스 캐릭터",
    "author": "nextain",
    "owner": "nextain",
    "license": "CC-BY-4.0",
    "created": "2026-06-21"
  },
  "canvas": {
    "width": 360,
    "height": 640,
    "fps": 25
  },
  "background": {
    "type": "color",
    "color": "#202830"
  },
  "poses": [
    "standing",
    "sitting"
  ],
  "animations": {
    "stand_talk": {
      "clip": "clips/stand_idle.webm",
      "entry_pose": "standing",
      "exit_pose": "standing",
      "loop": true,
      "can_talk": true,
      "face_bbox": [
        0.417,
        0.234,
        0.167
      ],
      "label": "서서 말하기"
    },
    "sit_talk": {
      "clip": "clips/sit_idle.webm",
      "entry_pose": "sitting",
      "exit_pose": "sitting",
      "loop": true,
      "can_talk": true,
      "face_bbox": [
        0.417,
        0.456,
        0.167
      ],
      "label": "앉아서 말하기"
    },
    "dance": {
      "clip": "clips/dance.webm",
      "entry_pose": "standing",
      "exit_pose": "standing",
      "loop": false,
      "can_talk": false,
      "label": "춤"
    },
    "wave": {
      "clip": "clips/wave.webm",
      "entry_pose": "standing",
      "exit_pose": "standing",
      "loop": false,
      "can_talk": false,
      "label": "인사"
    },
    "nod": {
      "clip": "clips/nod.webm",
      "entry_pose": "standing",
      "exit_pose": "standing",
      "loop": false,
      "can_talk": false,
      "label": "끄덕임"
    },
    "sit_down": {
      "clip": "clips/sit_down.webm",
      "entry_pose": "standing",
      "exit_pose": "sitting",
      "loop": false,
      "can_talk": false,
      "label": "앉기"
    },
    "stand_up": {
      "clip": "clips/stand_up.webm",
      "entry_pose": "sitting",
      "exit_pose": "standing",
      "loop": false,
      "can_talk": false,
      "label": "일어서기"
    }
  },
  "scenario": {
    "nodes": {
      "start": {
        "type": "start",
        "label": "진입"
      },
      "n0": {
        "type": "scene",
        "animation": "stand_talk",
        "label": "안녕하세요, 강남구청 안내 키오스크입니다",
        "dwell_ms": 2500
      },
      "n1": {
        "type": "scene",
        "animation": "wave",
        "label": "무엇을 도와드릴까요?",
        "dwell_ms": 2200
      },
      "n2": {
        "type": "scene",
        "animation": "sit_talk",
        "label": "민원실은 본관 2층에 있습니다",
        "dwell_ms": 3000
      },
      "n3": {
        "type": "scene",
        "animation": "stand_talk",
        "label": "더 도와드릴까요?",
        "dwell_ms": 2000
      }
    },
    "edges": [
      {
        "from": "start",
        "to": "n0"
      },
      {
        "from": "n0",
        "to": "n1"
      },
      {
        "from": "n1",
        "to": "n2"
      },
      {
        "from": "n2",
        "to": "n3"
      }
    ]
  },
  "chroma_key": "#00b140",
  "state_engine": {
    "version": "0.1",
    "default_state": "neutral",
    "visemes": [
      "sil",
      "a",
      "i",
      "u",
      "e",
      "o"
    ],
    "states": {
      "neutral": {
        "label": "neutral",
        "idle": "clips/stand_idle.webm",
        "talking_body": "clips/stand_idle.webm",
        "face_preview": "expressions/neutral.png",
        "face_bbox": [
          0.36,
          0.02,
          0.28,
          0.24
        ],
        "talking_heads": {
          "sil": "clips/viseme-sil.webm",
          "a": "clips/viseme-a.webm",
          "i": "clips/viseme-i.webm",
          "u": "clips/viseme-u.webm",
          "e": "clips/viseme-e.webm",
          "o": "clips/viseme-o.webm"
        },
        "sync": {
          "default_hold_ms": 160,
          "heads": {
            "sil": {
              "fps": 25,
              "duration_ms": 1200,
              "loopable": true,
              "hold_min_ms": 80,
              "hold_max_ms": 240,
              "mouth_peak_ms": 0
            },
            "a": {
              "fps": 25,
              "duration_ms": 1200,
              "loopable": true,
              "hold_min_ms": 80,
              "hold_max_ms": 240,
              "mouth_peak_ms": 120
            },
            "i": {
              "fps": 25,
              "duration_ms": 1200,
              "loopable": true,
              "hold_min_ms": 80,
              "hold_max_ms": 240,
              "mouth_peak_ms": 120
            },
            "u": {
              "fps": 25,
              "duration_ms": 1200,
              "loopable": true,
              "hold_min_ms": 80,
              "hold_max_ms": 240,
              "mouth_peak_ms": 120
            },
            "e": {
              "fps": 25,
              "duration_ms": 1200,
              "loopable": true,
              "hold_min_ms": 80,
              "hold_max_ms": 240,
              "mouth_peak_ms": 120
            },
            "o": {
              "fps": 25,
              "duration_ms": 1200,
              "loopable": true,
              "hold_min_ms": 80,
              "hold_max_ms": 240,
              "mouth_peak_ms": 120
            }
          }
        }
      }
    }
  }
}
