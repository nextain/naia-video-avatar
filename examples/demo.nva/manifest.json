{
  "nva_version": "0.1",
  "meta": {
    "name": "데모 박스 캐릭터",
    "author": "nextain",
    "owner": "nextain",
    "license": "CC-BY-4.0",
    "created": "2026-06-21"
  },
  "canvas": { "width": 360, "height": 640, "fps": 25 },
  "background": { "type": "color", "color": "#202830" },
  "poses": ["standing", "sitting"],
  "initial": "stand_talk",
  "states": {
    "stand_talk": {
      "kind": "talking", "clip": "clips/stand_idle.webm",
      "entry_pose": "standing", "exit_pose": "standing",
      "loop": true, "can_talk": true, "face_bbox": [0.417, 0.234, 0.167, 0.125],
      "label": "서서 말하기"
    },
    "sit_talk": {
      "kind": "talking", "clip": "clips/sit_idle.webm",
      "entry_pose": "sitting", "exit_pose": "sitting",
      "loop": true, "can_talk": true, "face_bbox": [0.417, 0.456, 0.167, 0.113],
      "label": "앉아서 말하기"
    },
    "dance": {
      "kind": "animation", "clip": "clips/dance.webm",
      "entry_pose": "standing", "exit_pose": "standing",
      "loop": false, "can_talk": false, "label": "춤"
    },
    "wave": {
      "kind": "animation", "clip": "clips/wave.webm",
      "entry_pose": "standing", "exit_pose": "standing",
      "loop": false, "can_talk": false, "label": "인사"
    },
    "nod": {
      "kind": "animation", "clip": "clips/nod.webm",
      "entry_pose": "standing", "exit_pose": "standing",
      "loop": false, "can_talk": false, "label": "끄덕임"
    }
  },
  "transitions": {
    "sit_down": {
      "clip": "clips/sit_down.webm",
      "entry_pose": "standing", "exit_pose": "sitting", "label": "앉기"
    },
    "stand_up": {
      "clip": "clips/stand_up.webm",
      "entry_pose": "sitting", "exit_pose": "standing", "label": "일어서기"
    }
  },
  "scenarios": {
    "greet_guide": {
      "label": "민원 안내",
      "steps": [
        { "goto": "stand_talk", "say": "안녕하세요, 강남구청 안내 키오스크입니다", "dwell_ms": 2500 },
        { "event": "wave", "say": "무엇을 도와드릴까요?", "dwell_ms": 2200 },
        { "goto": "sit_talk", "say": "민원실은 본관 2층에 있습니다", "dwell_ms": 3000 },
        { "goto": "stand_talk", "say": "더 도와드릴까요?", "dwell_ms": 2000 }
      ]
    },
    "directions": {
      "label": "길 안내",
      "steps": [
        { "goto": "stand_talk", "say": "어디로 가시나요?", "dwell_ms": 2000 },
        { "event": "nod", "say": "네, 안내해 드리겠습니다", "dwell_ms": 2000 },
        { "goto": "stand_talk", "say": "정문에서 좌회전하시면 됩니다", "dwell_ms": 3000 }
      ]
    },
    "welcome": {
      "label": "환영 인사",
      "steps": [
        { "event": "wave", "say": "환영합니다!", "dwell_ms": 2000 },
        { "event": "dance", "say": "강남구에 오신 것을 환영합니다", "dwell_ms": 2500 },
        { "goto": "stand_talk", "say": "무엇을 도와드릴까요?", "dwell_ms": 2000 }
      ]
    },
    "farewell": {
      "label": "작별 인사",
      "steps": [
        { "goto": "stand_talk", "say": "이용해 주셔서 감사합니다", "dwell_ms": 2500 },
        { "event": "wave", "say": "안녕히 가세요!", "dwell_ms": 2200 }
      ]
    }
  }
}
