{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://naia.land/nva/0.3/schema.json",
  "title": "Naia Video Avatar state-resource manifest v0.3",
  "type": "object",
  "required": ["nva_version", "contract", "revision", "canvas", "default_character_state_id", "character_states"],
  "additionalProperties": true,
  "properties": {
    "nva_version": { "const": "0.3" },
    "contract": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": { "const": "nva-state-resource" },
        "version": { "const": "1.0" }
      }
    },
    "revision": { "$ref": "#/$defs/revision" },
    "canvas": {
      "type": "object",
      "required": ["width", "height"],
      "properties": {
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "fps": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "default_character_state_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._+-]{0,127}$" },
    "character_states": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": { "pattern": "^[A-Za-z0-9][A-Za-z0-9._+-]{0,127}$" },
      "additionalProperties": { "$ref": "#/$defs/characterState" }
    },
    "gestures": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/gesture" }
    },
    "state_engine": false,
    "viseme_clips": false,
    "prebaked_speech": false,
    "audio_path": false,
    "endpoint": false,
    "cascade_endpoint": false,
    "cascade_url": false,
    "remote_endpoint": false
  },
  "$defs": {
    "revision": {
      "type": "object",
      "required": ["id"],
      "properties": { "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._+-]{0,127}$" } },
      "additionalProperties": true
    },
    "resource": {
      "type": "object",
      "required": ["path", "revision"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "revision": { "$ref": "#/$defs/revision" },
        "media_type": { "type": "string" },
        "sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" }
      },
      "additionalProperties": true
    },
    "faceBbox": {
      "type": "object",
      "required": ["schema_version", "source_width", "source_height", "coordinate_space", "x", "y", "width", "height", "anchor_frame", "confidence", "detector_version", "drift_report"],
      "properties": {
        "schema_version": { "const": "1.0" },
        "source_width": { "type": "integer", "minimum": 1 },
        "source_height": { "type": "integer", "minimum": 1 },
        "coordinate_space": { "const": "normalized_0_1" },
        "x": { "type": "number", "minimum": 0, "maximum": 1 },
        "y": { "type": "number", "minimum": 0, "maximum": 1 },
        "width": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
        "height": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
        "anchor_frame": { "type": "integer", "minimum": 0 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "detector_version": { "type": "string", "minLength": 1 },
        "drift_report": {
          "type": "object",
          "required": ["max_normalized_displacement"],
          "properties": { "max_normalized_displacement": { "type": "number", "minimum": 0 } }
        }
      }
    },
    "talkingHead": {
      "type": "object",
      "required": ["revision", "source", "descriptor"],
      "properties": {
        "revision": { "$ref": "#/$defs/revision" },
        "source": { "$ref": "#/$defs/resource" },
        "descriptor": {
          "type": "object",
          "required": ["schema_version", "kind", "profile_ref"],
          "properties": {
            "schema_version": { "const": "1.0" },
            "kind": { "type": "string", "minLength": 1 },
            "profile_ref": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": true
        }
      }
    },
    "characterState": {
      "type": "object",
      "required": ["revision", "idle", "talking_body", "talking_head", "face_bbox"],
      "properties": {
        "label": { "type": "string" },
        "revision": { "$ref": "#/$defs/revision" },
        "idle": { "$ref": "#/$defs/resource" },
        "talking_body": { "$ref": "#/$defs/resource" },
        "talking_head": { "$ref": "#/$defs/talkingHead" },
        "face_bbox": { "$ref": "#/$defs/faceBbox" }
      }
    },
    "gesture": {
      "type": "object",
      "required": ["revision", "clip", "allowed_character_state_ids", "return_policy"],
      "properties": {
        "label": { "type": "string" },
        "revision": { "$ref": "#/$defs/revision" },
        "clip": { "$ref": "#/$defs/resource" },
        "allowed_character_state_ids": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "return_policy": { "const": "same-character-state" }
      }
    }
  }
}
