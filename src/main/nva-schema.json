{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nextain.io/nva/0.2/schema.json",
  "title": "Naia Video Avatar manifest v0.2",
  "type": "object",
  "required": ["nva_version", "canvas", "animations", "state_engine"],
  "additionalProperties": true,
  "not": {
    "anyOf": [
      { "required": ["viseme_clips"] },
      { "required": ["audio_path"] },
      { "required": ["prebaked_speech"] }
    ]
  },
  "properties": {
    "nva_version": { "type": "string", "const": "0.2" },
    "meta": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "author": { "type": "string" },
        "owner": { "type": "string" },
        "license": { "type": "string" }
      }
    },
    "canvas": {
      "type": "object",
      "required": ["width", "height"],
      "additionalProperties": true,
      "properties": {
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "fps": { "type": "integer", "minimum": 1, "default": 25 }
      }
    },
    "background": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": { "enum": ["color", "image", "video", "transparent"] },
        "color": { "type": "string" },
        "src": { "type": "string" }
      }
    },
    "chroma_key": { "type": "string" },
    "poses": { "type": "array", "items": { "type": "string" } },
    "animations": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["clip"],
        "additionalProperties": true,
        "properties": {
          "clip": { "type": "string" },
          "entry_pose": { "type": "string" },
          "exit_pose": { "type": "string" },
          "loop": { "type": "boolean", "default": false },
          "can_talk": { "type": "boolean", "default": false },
          "kind": { "type": "string" },
          "face_bbox": {
            "type": "array",
            "items": { "type": "number", "minimum": 0, "maximum": 1 },
            "minItems": 4,
            "maxItems": 4
          },
          "label": { "type": "string" },
          "intent": { "type": "string" },
          "triggers": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "state_engine": {
      "type": "object",
      "required": ["default_state", "visemes", "states"],
      "additionalProperties": true,
      "properties": {
        "default_state": { "type": "string" },
        "visemes": {
          "description": "Held six-head prototype keys. This does not define the final talking-head transition contract.",
          "type": "array",
          "minItems": 6,
          "contains": { "const": "sil" },
          "allOf": [
            { "contains": { "const": "a" } },
            { "contains": { "const": "i" } },
            { "contains": { "const": "u" } },
            { "contains": { "const": "e" } },
            { "contains": { "const": "o" } }
          ],
          "items": { "enum": ["sil", "a", "i", "u", "e", "o"] }
        },
        "states": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": { "enum": ["neutral", "happy", "sad", "angry", "surprised", "thinking"] },
          "additionalProperties": {
            "type": "object",
            "required": ["idle", "talking_body", "talking_heads", "face_preview", "face_bbox", "sync"],
            "additionalProperties": true,
            "properties": {
              "label": { "type": "string" },
              "idle": { "type": "string" },
              "talking_body": { "type": "string" },
              "face_preview": { "type": "string" },
              "talking_head_crop": { "type": "boolean" },
              "face_bbox": {
                "type": "array",
                "items": { "type": "number", "minimum": 0, "maximum": 1 },
                "minItems": 4,
                "maxItems": 4
              },
              "talking_heads": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              },
              "sync": {
                "type": "object",
                "required": ["default_hold_ms", "heads"],
                "additionalProperties": true,
                "properties": {
                  "default_hold_ms": { "type": "integer", "minimum": 1 },
                  "heads": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "object",
                      "required": ["duration_ms", "fps", "loopable"],
                      "additionalProperties": true,
                      "properties": {
                        "duration_ms": { "type": "integer", "minimum": 1 },
                        "fps": { "type": "number", "exclusiveMinimum": 0 },
                        "loopable": { "type": "boolean" },
                        "offset_ms": { "type": "number" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "nodes": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["type"],
            "additionalProperties": true,
            "properties": {
              "type": { "enum": ["start", "scene"] },
              "animation": { "type": "string" },
              "label": { "type": "string" },
              "dwell_ms": { "type": "integer", "minimum": 0 }
            }
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "to"],
            "additionalProperties": true,
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" }
            }
          }
        }
      }
    },
    "vrm_slots": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "idle": { "type": "string" },
        "talk": { "type": "string" },
        "listening": { "type": "string" },
        "events": { "type": "object", "additionalProperties": { "type": "string" } },
        "profile": { "type": "object", "additionalProperties": true },
        "expressions": { "type": "object", "additionalProperties": true },
        "motions": { "type": "object", "additionalProperties": true }
      }
    }
  }
}
